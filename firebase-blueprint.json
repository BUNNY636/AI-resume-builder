{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Resume": {
      "title": "Resume",
      "description": "A tailored resume entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "jobDescription": { "type": "string" },
        "rawExperience": { "type": "string" },
        "tailoredData": {
          "type": "object",
          "description": "The JSON structure of the tailored resume"
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "jobDescription", "rawExperience", "tailoredData", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/resumes/{resumeId}": {
      "schema": "Resume",
      "description": "Tailored resume documents"
    }
  }
}
